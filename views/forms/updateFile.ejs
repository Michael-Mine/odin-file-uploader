<!DOCTYPE html>
<html lang="en">
  <%- include("../partials/head.ejs") %>
  <body>
    <%- include("../partials/nav.ejs") %>
    <h1><%= file.files[0].name %></h1>

    <%- include("../partials/errors.ejs") %>

    <form method="POST" action="/file/<%= file.files[0].cuid %>/update">
      <p class="input-container">
        <label for="name">File Rename:</label>
        <input
          type="text"
          name="name"
          id="name"
          value="<%= file.files[0].name %>"
        />
      </p>

      <button type="submit">Submit</button>
    </form>
  </body>
</html>
